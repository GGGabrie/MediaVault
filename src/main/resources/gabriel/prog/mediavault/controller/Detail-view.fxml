<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gabriel.prog.mediavault.controller.DetailController" spacing="10" style="-fx-padding: 20;">

    <Label text="Medien-Details" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Separator/>

    <GridPane hgap="15" vgap="10">
        <Label text="Titel:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="titleLabel" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size: 14px;"/>
        <Label text="Kategorie:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="categoryLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Bewertung:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="ratingLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Status:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <Label fx:id="statusLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        <Label text="Beschreibung:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <TextArea fx:id="descriptionArea" GridPane.rowIndex="4" GridPane.columnIndex="1" editable="false" wrapText="true" prefHeight="100" prefWidth="400"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Schließen" onAction="#handleClose"/>
    </HBox>

</VBox>