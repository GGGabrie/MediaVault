<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" style="-fx-padding: 20;" stylesheets="@Detail.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gabriel.prog.mediavault.controller.DetailController">

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Medien-Details" />

    <Separator />

    <GridPane hgap="15" vgap="10">
        <Label style="-fx-font-weight: bold;" text="Titel:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <Label fx:id="titleLabel" style="-fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Label style="-fx-font-weight: bold;" text="Kategorie:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <Label fx:id="categoryLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Label style="-fx-font-weight: bold;" text="Bewertung:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Label fx:id="ratingLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        <Label style="-fx-font-weight: bold;" text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <Label fx:id="statusLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <Label style="-fx-font-weight: bold;" text="Beschreibung:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextArea fx:id="descriptionArea" editable="false" prefHeight="100" prefWidth="400" styleClass="text-area" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4">
         <opaqueInsets>
            <Insets />
         </opaqueInsets></TextArea>
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button styleClass="button" onAction="#handleClose" text="Schließen" />
    </HBox>

</VBox>
