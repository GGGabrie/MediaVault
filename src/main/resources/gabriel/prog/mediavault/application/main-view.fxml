<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gabriel.prog.mediavault.controller.MainController">

    <ToolBar>
        <Button onAction="#handleAddMedia" text="Neu" />
        <Button onAction="#handleEditMedia" text="Bearbeiten" />
        <Button onAction="#handleDeleteMedia" text="Löschen" />
        <Separator orientation="VERTICAL" />
        <Button onAction="#handleRefresh" text="Aktualisieren" />
        <ComboBox fx:id="categoryFilter" onAction="#handleFilterChange" promptText="Kategorie" />
        <ComboBox fx:id="ratingFilter" onAction="#handleFilterChange" promptText="Bewertung" />
        <ComboBox fx:id="statusFilter" onAction="#handleFilterChange" promptText="Status" />
        <Separator orientation="VERTICAL" />
        <TextField fx:id="searchField" onKeyReleased="#handleSearch" promptText="Suchen..." />
        <Button onAction="#handleClearSearch" style="-fx-font-size: 10px;" text="x" />
    </ToolBar>


    <TableView fx:id="mediaTable">
        <columns>
            <TableColumn prefWidth="250" text="Titel">
                <cellValueFactory><PropertyValueFactory property="title" /></cellValueFactory>
            </TableColumn>
            <TableColumn prefWidth="120" text="Kategorie">
                <cellValueFactory><PropertyValueFactory property="category" /></cellValueFactory>
            </TableColumn>
            <TableColumn prefWidth="80" style="-fx-alignment: CENTER;" text="Bewertung">
                <cellValueFactory><PropertyValueFactory property="rating" /></cellValueFactory>
                <cellFactory>
                    <javafx.scene.control.cell.TextFieldTableCell fx:factory="forTableColumn" />
                </cellFactory>
            </TableColumn>
            <TableColumn prefWidth="120" style="-fx-alignment: CENTER;" text="Status">
                <cellValueFactory><PropertyValueFactory property="status" /></cellValueFactory>
                <cellFactory>
                    <javafx.scene.control.cell.TextFieldTableCell fx:factory="forTableColumn" />
                </cellFactory>
            </TableColumn>
            <TableColumn prefWidth="400" text="Beschreibung">
                <cellValueFactory><PropertyValueFactory property="description" /></cellValueFactory>
            </TableColumn>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox styleClass="status-bar">
        <Label fx:id="statusLabel" text="0 Medien gefunden" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Details" onAction="#handleShowDetails" alignment="BOTTOM_RIGHT"/>
        <Separator orientation="VERTICAL" />
        <Button text="Status umschalten" onAction="#handleToggleStatus"/>
    </HBox>

</VBox>
